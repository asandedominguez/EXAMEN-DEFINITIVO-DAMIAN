import java.util.Scanner;
import java.util.List;

/**
 * Clase que se encarga de mostrar la información en pantalla (Vista).
 * * @author Adrián Sande Domínguez
 * @version 6.9
 */
public class View {

    public void mostrarMenu() {
        Controller controlador = new Controller();
        Scanner teclado = new Scanner(System.in);
        int opcionSeleccionada = 0;

        do {
            System.out.println("\n=== GESTIÓN DE PARKING ===");
            System.out.println("1. Agregar Coche");
            System.out.println("2. Quitar Coche");
            System.out.println("3. Avanzar Coche");
            System.out.println("4. Añadir velocidad");
            System.out.println("5. Mostrar velocidad del coche");
            System.out.println("6. Coches en el parking");
            System.out.println("7. Salir");
            System.out.println("8. Poner Gasolina (Máx 25L)"); // <- Nueva opción integrada
            System.out.print("Seleccione una opción: ");

            try {
                opcionSeleccionada = Integer.parseInt(teclado.nextLine());
            } catch (NumberFormatException e) {
                opcionSeleccionada = 0;
            }

            switch (opcionSeleccionada) {
                case 1:
                    System.out.println("\n--- Agregar Coche ---");
                    System.out.print("Introduce el modelo: ");
                    String modeloCoche = teclado.nextLine();
                    System.out.print("Introduce la matricula: ");
                    String matriculaCoche = teclado.nextLine();

                    boolean registrado = controlador.registrarCoche(modeloCoche, matriculaCoche);
                    if (registrado) {
                        System.out.println("¡Coche aparcado con éxito!");
                    } else {
                        System.out.println("¡FALLO FATAL!");
                    }
                    break;

                case 2:
                    System.out.println("\n--- Quitar Coche ---");
                    System.out.print("Introduce la matrícula del coche para quitar: ");
                    String matriculaQuitar = teclado.nextLine();

                    Coche cocheQuitado = controlador.eliminarCoche(matriculaQuitar);
                    if (cocheQuitado != null) {
                        System.out.println("Éxito: El coche con matrícula " + matriculaQuitar + " ha sido retirado.");
                    } else {
                        System.out.println("Error: No se encontró ningún coche con la matrícula " + matriculaQuitar + " en el parking.");
                    }
                    break;

                case 3:
                    System.out.println("\n--- Avanzar Coche ---");
                    System.out.print("Introduce la matrícula: ");
                    String matriculaAvanzar = teclado.nextLine();

                    Coche cocheEnMarcha = controlador.actualizarKilometros(matriculaAvanzar);
                    if (cocheEnMarcha != null) {
                        System.out.println("¡Avanzado! Kilómetros actuales de: " + cocheEnMarcha.kilometros);
                    } else {
                        System.out.println("El coche con matrícula " + matriculaAvanzar + " no está en el parking.");
                    }
                    break;

                case 4:
                    System.out.println("\n--- Cambiar Velocidad ---");
                    System.out.print("Introduce la matrícula: ");
                    String matriculaVelocidad = teclado.nextLine();
                    System.out.print("Introduce la nueva velocidad: ");

                    Integer nuevaVelocidadInput = teclado.nextInt();
                    teclado.nextLine(); // Limpia el buffer

                    int velocidadNueva = controlador.modificarVelocidad(matriculaVelocidad, nuevaVelocidadInput);
                    if (velocidadNueva != -1) {
                        System.out.println(" Velocidad actualizada con éxito a: " + velocidadNueva + " km/h.");
                    } else {
                        System.out.println(" Error: No se encontró ningún coche con la matrícula " + matriculaVelocidad);
                    }
                    break;

                case 5:
                    System.out.println("\n--- Mostrar velocidad del coche ---");
                    System.out.print("Introduce la matrícula del coche: ");
                    String matriculaConsulta = teclado.nextLine();

                    int velocidadActual = controlador.obtenerVelocidad(matriculaConsulta);
                    System.out.println("Velocidad actual del coche: " + velocidadActual + " km/h.");
                    break;

                case 6:
                    System.out.println("\n--- Coches en el parking ---");
                    List<Coche> listaCoches = controlador.obtenerListaCoches();
                    if (listaCoches.isEmpty()) {
                        System.out.println("El parking está vacío.");
                    } else {
                        for (Coche ch : listaCoches) {
                            // Muestra dinámicamente la gasolina asociada a la matrícula
                            int gas = controlador.obtenerGasolina(ch.matricula);
                            System.out.println("Modelo: " + ch.modelo + " | Matrícula: " + ch.matricula + " | Velocidad: " + ch.velocidad + " km/h" + " | Recorrido: " + ch.kilometros + " km | Gasolina: " + gas + "L");
                        }
                        System.out.println("----------------------------");
                    }
                    break;

                case 7:
                    System.out.println("\nSaliendo del programa... ¡Hasta pronto!");
                    break;

                case 8: // <- Lógica interactiva para poner gasolina con tope de 25
                    System.out.println("\n--- Poner Gasolina ---");
                    System.out.print("Introduce la matrícula: ");
                    String matGas = teclado.nextLine();
                    System.out.print("Introduce litros a repostar: ");
                    try {
                        int litrosInput = Integer.parseInt(teclado.nextLine());
                        int resultadoGas = controlador.ponerGasolina(matGas, litrosInput);
                        if (resultadoGas == -1) {
                            System.out.println("Error: El coche no existe en el parking.");
                        } else {
                            System.out.println("Tanque actualizado. Gasolina actual: " + resultadoGas + "L (Máximo permitido: 25L).");
                        }
                    } catch (NumberFormatException e) {
                        System.out.println("Error: Introduce una cantidad de litros válida.");
                    }
                    break;

                default:
                    System.out.println("Opción no válida. Por favor, elige un número del 1 al 8.");
                    break;
            }

        } while (opcionSeleccionada != 7);

        teclado.close();
    }
}

import java.lang.module.ModuleDescriptor;
import java.util.List;
import java.util.HashMap; // <- Importado en la misma clase

/**
 * Clase que actúa como Controlador del programa.
 * Gestiona el flujo de datos entre la interfaz y el modelo.
 * * @author Adrián Sande Domínguez
 * @version 6.9
 */
public class Controller {

    /** Instancia global para gestionar la interfaz del menú. */
    static View vistaMenu = new View();

    /** Instancia del modelo que sirve para guardar los datos de los coches en memoria. */
    Model baseDatos = new Model();

    /** Almacén interno para la gasolina sin crear clases nuevas */
    public static HashMap<String, Integer> gasolinaCoches = new HashMap<>();

    /**
     * Pone gasolina a un coche con un límite máximo de 25 litros.
     * @param matricula La placa del coche.
     * @param litros Cantidad de litros a introducir.
     * @return Los litros totales actuales, o -1 si el coche no existe.
     */
    public int ponerGasolina(String matricula, int litros) {
        if (baseDatos.obtenerCoche(matricula) == null) {
            return -1; // El coche no existe en el parking
        }

        int actuales = gasolinaCoches.getOrDefault(matricula, 0);
        int nuevoTotal = actuales + litros;

        if (nuevoTotal > 25) {
            nuevoTotal = 25; // Corrección máxima a 25 litros
        }

        gasolinaCoches.put(matricula, nuevoTotal);
        return nuevoTotal;
    }

    /**
     * Obtiene los litros de gasolina de un coche.
     */
    public int obtenerGasolina(String matricula) {
        return gasolinaCoches.getOrDefault(matricula, 0);
    }

    /**
     * Punto de partida por donde arranca la aplicación.
     * Inicia el menú principal en la pantalla del usuario.
     * * @param args Parámetros de la terminal (actualmente sin uso).
     */
    public static void main(String[] args) {
        vistaMenu.mostrarMenu();
    }

    public boolean registrarCoche(String modelo, String matricula){
        Coche nuevo = baseDatos.crearCoche(modelo, matricula);
        if (nuevo == baseDatos.obtenerCoche(matricula)) {
            return true;
        }
        return false;
    }

    public Coche eliminarCoche(String matricula) {
        Coche cocheQuitado = baseDatos.quitarCoche(matricula);
        if (cocheQuitado != null) {
            gasolinaCoches.remove(matricula); // Limpieza de gasolina al salir
        }
        return cocheQuitado;
    }

    public Coche actualizarKilometros(String matricula) {
        Coche cocheActualizado = baseDatos.hacerAvanzarCoche(matricula);
        return cocheActualizado;
    }

    public int modificarVelocidad(String matricula, Integer nuevaVelocidad) {
        int velocidadResultante = baseDatos.cambiarVelocidad(matricula, nuevaVelocidad);
        return velocidadResultante;
    }

    public int obtenerVelocidad(String matricula) {
        return baseDatos.obtenerVelocidad(matricula);
    }

    public List<Coche> obtenerListaCoches() {
        return baseDatos.obtenerListaParking();
    }
}
Estructura Coche
    Texto: matricula
    Texto: modelo
    Entero: velocidad
    Entero: kilometros
FinEstructura

Modulo Modelo
    // Lista global en memoria para guardar los coches
    Lista de Coche: listaParking <- Nueva Lista Vía Arreglo Dinámico

    Funcion crearCoche(Texto: mod, Texto: mat) Devuelve Coche
        Definir Coche: aux
        aux.modelo <- mod
        aux.matricula <- mat
        aux.velocidad <- 0
        aux.kilometros <- 0
        Agregar aux a listaParking
        Devolver aux
    FinFuncion

    Funcion obtenerCoche(Texto: mat) Devuelve Coche
        Para cada Coche c en listaParking Hacer
            Si c.matricula == mat Entonces
                Devolver c
            FinSi
        FinPara
        Devolver Nulo
    FinFuncion

    Funcion quitarCoche(Texto: mat) Devuelve Coche
        Definir Coche: cocheEncontrado <- obtenerCoche(mat)
        Si cocheEncontrado != Nulo Entonces
            Eliminar cocheEncontrado de listaParking
            Devolver cocheEncontrado
        FinSi
        Devolver Nulo
    FinFuncion

    Funcion cambiarVelocidad(Texto: mat, Entero: v) Devuelve Entero
        Definir Coche: c <- obtenerCoche(mat)
        Si c != Nulo Entonces
            c.velocidad <- v
            Devolver c.velocidad
        FinSi
        Devolver -1
    FinFuncion

    Funcion hacerAvanzarCoche(Texto: mat) Devuelve Coche
        Definir Coche: c <- obtenerCoche(mat)
        Si c != Nulo Entonces
            c.kilometros <- c.kilometros + 1
        FinSi
        Devolver c
    FinFuncion

    Funcion obtenerListaParking() Devuelve Lista de Coche
        Devolver listaParking
    FinFuncion
FinModulo

Modulo Controlador
    Instancia de Modelo: baseDatos <- Nuevo Modelo
    // Diccionario/Mapa para relacionar Matrícula -> Gasolina (Sin crear clases)
    Diccionario(Texto, Entero): gasolinaCoches <- Nuevo Diccionario

    Funcion registrarCoche(Texto: modelo, Texto: matricula) Devuelve Booleano
        Definir Coche: nuevo <- baseDatos.crearCoche(modelo, matricula)
        Si nuevo != Nulo Entonces
            Devolver Verdadero
        Sino
            Devolver Falso
        FinSi
    FinFuncion

    Funcion eliminarCoche(Texto: matricula) Devuelve Coche
        Definir Coche: removido <- baseDatos.quitarCoche(matricula)
        Si removido != Nulo Entonces
            Eliminar matricula de gasolinaCoches
        FinSi
        Devolver removido
    FinFuncion

    Funcion actualizarKilometros(Texto: matricula) Devuelve Coche
        Devolver baseDatos.hacerAvanzarCoche(matricula)
    FinFuncion

    Funcion modificarVelocidad(Texto: matricula, Entero: nuevaVelocidad) Devuelve Entero
        Devolver baseDatos.cambiarVelocidad(matricula, nuevaVelocidad)
    FinFuncion

    Funcion obtenerVelocidad(Texto: matricula) Devuelve Entero
        Definir Coche: c <- baseDatos.obtenerCoche(matricula)
        Si c != Nulo Entonces
            Devolver c.velocidad
        FinSi
        Devolver -1
    FinFuncion

    Funcion ponerGasolina(Texto: matricula, Entero: litros) Devuelve Entero
        // Validar si el coche existe en el modelo
        Si baseDatos.obtenerCoche(matricula) == Nulo Entonces
            Devolver -1
        FinSi

        Definir Entero: actuales <- 0
        Si Existe matricula en gasolinaCoches Entonces
            actuales <- Obtener valor de matricula en gasolinaCoches
        FinSi

        Definir Entero: nuevoTotal <- actuales + litros

        // CORRECCIÓN MÁXIMA A 25 LITROS
        Si nuevoTotal > 25 Entonces
            nuevoTotal <- 25
        FinSi

        Guardar nuevoTotal en gasolinaCoches bajo la clave matricula
        Devolver nuevoTotal
    FinFuncion

    Funcion obtenerGasolina(Texto: matricula) Devuelve Entero
        Si Existe matricula en gasolinaCoches Entonces
            Devolver Obtener valor de matricula en gasolinaCoches
        Sino
            Devolver 0
        FinSi
    FinFuncion

    Funcion obtenerListaCoches() Devuelve Lista de Coche
        Devolver baseDatos.obtenerListaParking()
    FinFuncion
FinModulo

