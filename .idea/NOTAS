    Funcion mostrarMenu()
        Instancia de Controlador: controlador <- Nuevo Controlador
        Definir Entero: opcionSeleccionada <- 0
        Definir Texto: entradaMatricula, entradaModelo

        Repetir
            Escribir "=== GESTIÓN DE PARKING ==="
            Escribir "1. Agregar Coche"
            Escribir "2. Quitar Coche"
            Escribir "3. Avanzar Coche"
            Escribir "4. Añadir velocidad"
            Escribir "5. Mostrar velocidad del coche"
            Escribir "6. Coches en el parking"
            Escribir "7. Salir"
            Escribir "8. Poner Gasolina (Máx 25L)"
            Escribir "Seleccione una opción: "
            Leer opcionSeleccionada

            En Caso De opcionSeleccionada Hacer
                1:
                    Escribir "--- Agregar Coche ---"
                    Escribir "Introduce el modelo: "
                    Leer entradaModelo
                    Escribir "Introduce la matrícula: "
                    Leer entradaMatricula
                    Si controlador.registrarCoche(entradaModelo, entradaMatricula) Entonces
                        Escribir "¡Coche aparcado con éxito!"
                    Sino
                        Escribir "¡FALLO FATAL!"
                    FinSi

                2:
                    Escribir "--- Quitar Coche ---"
                    Escribir "Introduce la matrícula: "
                    Leer entradaMatricula
                    Si controlador.eliminarCoche(entradaMatricula) != Nulo Entonces
                        Escribir "Éxito: Vehículo retirado."
                    Sino
                        Escribir "Error: No se encontró el coche."
                    FinSi

                3:
                    Escribir "--- Avanzar Coche ---"
                    Escribir "Introduce la matrícula: "
                    Leer entradaMatricula
                    Definir Coche: c <- controlador.actualizarKilometros(entradaMatricula)
                    Si c != Nulo Entonces
                        Escribir "¡Avanzado! Kilómetros actuales: ", c.kilometros
                    Sino
                        Escribir "El coche no está en el parking."
                    FinSi

                4:
                    Escribir "--- Cambiar Velocidad ---"
                    Escribir "Introduce la matrícula: "
                    Leer entradaMatricula
                    Definir Entero: nuevaVel
                    Escribir "Introduce nueva velocidad: "
                    Leer nuevaVel
                    Si controlador.modificarVelocidad(entradaMatricula, nuevaVel) != -1 Entonces
                        Escribir "Velocidad actualizada."
                    Sino
                        Escribir "Error: Matrícula no encontrada."
                    FinSi

                5:
                    Escribir "--- Mostrar Velocidad ---"
                    Escribir "Introduce la matrícula: "
                    Leer entradaMatricula
                    Definir Entero: vel <- controlador.obtenerVelocidad(entradaMatricula)
                    Si vel != -1 Entonces
                        Escribir "Velocidad actual: ", vel, " km/h."
                    Sino
                        Escribir "Error: Vehículo inexistente."
                    FinSi

                6:
                    Escribir "--- Coches en el Parking ---"
                    Lista de Coche: lista <- controlador.obtenerListaCoches()
                    Si lista estaVacia Entonces
                        Escribir "El parking está vacío."
                    Sino
                        Para cada Coche ch en lista Hacer
                            Definir Entero: gas <- controlador.obtenerGasolina(ch.matricula)
                            Escribir "Modelo: ", ch.modelo, " | Matrícula: ", ch.matricula, " | Velocidad: ", ch.velocidad, " km/h | KM: ", ch.kilometros, " | Gasolina: ", gas, "L"
                        FinPara
                    FinSi

                7:
                    Escribir "Saliendo del programa... ¡Hasta pronto!"

                8:
                    Escribir "--- Poner Gasolina ---"
                    Escribir "Introduce la matrícula: "
                    Leer entradaMatricula
                    Definir Entero: litrosInput
                    Escribir "Introduce litros a repostar: "
                    Leer litrosInput

                    Definir Entero: resultadoGas <- controlador.ponerGasolina(entradaMatricula, litrosInput)
                    Si resultadoGas == -1 Entonces
                        Escribir "Error: El coche no existe en el parking."
                    Sino
                        Escribir "Tanque actualizado. Gasolina actual: ", resultadoGas, "L (Máximo: 25L)."
                    FinSi

                OtroCaso:
                    Escribir "Opción no válida. Intente de nuevo."
            FinCaso
        Hasta Que opcionSeleccionada == 7
    FinFuncion
